if (!$vaksin) {
    echo "Data vaksin tidak ditemukan.";
    exit;
}

// Proses update
if ($_SERVER["REQUEST_METHOD"] === "POST") {
    $id        = $_POST['id_vaksin'];
    $nama      = $_POST['nama_vaksin'];
    $umur_min  = $_POST['umur_min'];
    $umur_max  = $_POST['umur_max'];
    
    $sql = "UPDATE vaksin SET 
                id_vaksin = '$id',
                nama_vaksin = '$nama',
                umur_min = '$umur_min',
                umur_max = '$umur_max'
            WHERE id_vaksin = '$id_vaksin'";

    if (mysqli_query($connect, $sql)) {
        echo '<script>alert("Data vaksin berhasil diperbarui!"); window.location.href = "dashboard_admin.php";</script>';
        exit;
    } else {
        echo "Gagal memperbarui data: " . mysqli_error($connect);
    }
}
